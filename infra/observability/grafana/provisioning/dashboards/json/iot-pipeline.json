{
  "id": null,
  "uid": "anees-iot-pipeline",
  "title": "IoT Pipeline",
  "tags": ["anees", "iot"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "MQTT Messages / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(mqtt_messages_received_total[1m])",
          "legendFormat": "messages/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "DSP Processing Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(dsp_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(dsp_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(dsp_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Vital Readings Insert Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(vital_readings_inserted_total[1m])",
          "legendFormat": "inserts/sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "title": "BullMQ Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bullmq_queue_depth{queue=\"fall-alert\"}",
          "legendFormat": "fall-alert"
        },
        {
          "expr": "bullmq_queue_depth{queue=\"push-notifications\"}",
          "legendFormat": "push-notifications"
        },
        {
          "expr": "bullmq_queue_depth{queue=\"sleep-aggregation\"}",
          "legendFormat": "sleep-aggregation"
        },
        {
          "expr": "bullmq_queue_depth{queue=\"anomaly-detection\"}",
          "legendFormat": "anomaly-detection"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "DSP Validation Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(dsp_validation_errors_total[1h])",
          "legendFormat": "errors (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "MQTT Forward Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(mqtt_forward_failures_total[1h])",
          "legendFormat": "failures (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Redis Publish Latency",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(redis_publish_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "Pipeline Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "{service=~\"backend|dsp\"} |= \"mqtt\" or |= \"vital\" or |= \"dsp\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "pluginId": "loki",
        "label": "Loki",
        "current": {}
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" }
}
