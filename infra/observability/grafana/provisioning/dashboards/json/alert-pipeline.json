{
  "id": null,
  "uid": "anees-alert-pipeline",
  "title": "Alert Pipeline",
  "tags": ["anees", "alerts"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Fall Detections / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(fall_detections_total[1h])",
          "legendFormat": "falls"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Alert Dispatch Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(alert_dispatch_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Push Notification Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(push_notifications_sent_total{status=\"success\"}[5m]) / rate(push_notifications_sent_total[5m]) * 100",
          "legendFormat": "success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Alerts by Status",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (status) (alerts_total)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Fall Detections Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(fall_detections_total[10m])",
          "legendFormat": "falls (10m window)"
        },
        {
          "expr": "increase(fall_cancellations_total[10m])",
          "legendFormat": "cancelled by user"
        },
        {
          "expr": "increase(alerts_dispatched_total[10m])",
          "legendFormat": "dispatched to caregiver"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Alert Dispatch Latency Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(alert_dispatch_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(alert_dispatch_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(alert_dispatch_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Vital Anomaly Alerts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(vital_anomaly_alerts_total[10m])",
          "legendFormat": "anomaly alerts (10m)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Alert Pipeline Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "{service=\"backend\"} |= \"fall\" or |= \"alert\" or |= \"dispatch\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "pluginId": "loki",
        "label": "Loki",
        "current": {}
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" }
}
