# ─── Device identity ──────────────────────────────────────────────────────────
DEVICE_ID=your-device-uuid
DEVICE_SERIAL=BD60S1-XXXX

# ─── Backend connection ───────────────────────────────────────────────────────
# The Anees backend WebSocket base URL
SOCKET_BASE_URL=http://api.localhost
# JWT access token for this device's patient account (rotated via /auth/refresh)
DEVICE_JWT=

# ─── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_WS_URL=ws://livekit.localhost

# ─── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://hivemq:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Audio device (ALSA/PulseAudio sink and source) ──────────────────────────
# Leave empty to use system default
AUDIO_SINK=default
AUDIO_SOURCE=default
