# ─── PostgreSQL / TimescaleDB ─────────────────────────────────────────────────
POSTGRES_USER=anees
POSTGRES_PASSWORD=anees_dev_secret
POSTGRES_DB=anees

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=anees_redis_dev

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── Coturn / TURN ───────────────────────────────────────────────────────────
TURN_USER=anees
TURN_PASSWORD=turn_dev_secret

# ─── LiveKit ─────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ─── Traefik ──────────────────────────────────────────────────────────────────
# Dashboard available at http://localhost:8888 or http://traefik.localhost
# All HTTP services are routed via Traefik on port 80 using .localhost domains.

# ─── Super-admin console (development defaults only) ─────────────────────────
ADMIN_NEXTAUTH_SECRET=change_me_admin_nextauth_secret
ADMIN_NEXTAUTH_URL=http://admin.localhost
ADMIN_AUTH_COOKIE=anees-admin.session-token
INTERNAL_API_URL=http://backend:3000
